<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Heredar del botón de categoría del POS para aplicar colores personalizados -->
    <t t-name="pos_restaurant.CategoryButton" t-inherit="point_of_sale.CategoryButton" t-inherit-mode="extension">
        <xpath expr="//button[contains(@class, 'category-button')]" position="attributes">
            <attribute name="t-attf-style">
                #{props.category.color !== undefined ? `background-color: var(--colorlist-color-#{props.category.color}) !important;` : ''}
            </attribute>
        </xpath>
    </t>
</templates>
