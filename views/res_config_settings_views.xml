<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_colorlist" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.colorlist</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Colores" string="Colores" name="colorlist_customizer" logo="/colorlist_customizer/static/description/icon.svg">
                    <block title="Colores del Selector de Color" name="colorlist_settings_container">
                        <setting>
                            <field name="color_0" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_1" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_2" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_3" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_4" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_5" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_6" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_7" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_8" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_9" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_10" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_11" widget="color"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
