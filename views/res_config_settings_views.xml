<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_customize_pos" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.customize.pos</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Personalizar TPV" string="Personalizar TPV" name="customize_pos" logo="/customize_pos/static/description/icon.svg">
                    <block title="Colores de Categorías" name="color_settings_container">
                        <setting>
                            <field name="color_0" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_1" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_2" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_3" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_4" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_5" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_6" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_7" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_8" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_9" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_10" widget="color"/>
                        </setting>
                        <setting>
                            <field name="color_11" widget="color"/>
                        </setting>
                    </block>
                    <block title="Opciones de Visualización del TPV" name="pos_display_settings_container">
                        <setting string="Nombres de productos en mayúsculas" help="Muestra los nombres de los productos en mayúsculas en la pantalla del TPV">
                            <field name="product_names_uppercase"/>
                        </setting>
                        <setting string="Nombres de categorías en mayúsculas" help="Muestra los nombres de las categorías en mayúsculas en la pantalla del TPV">
                            <field name="category_names_uppercase"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
